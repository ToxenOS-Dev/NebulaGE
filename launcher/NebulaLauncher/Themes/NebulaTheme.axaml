<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════
         NebulaGE Color Palette — DEFAULT VALUES
         These are overridden at runtime by ThemeManager.Apply()
         via Application.Current.Resources (DynamicResource wins).
         ══════════════════════════════════════════════════ -->
    <Styles.Resources>

        <!-- Backgrounds -->
        <Color x:Key="NebulaBg">#0F0F11</Color>
        <Color x:Key="NebulaSurface">#16161A</Color>
        <Color x:Key="NebulaSurface2">#1C1C21</Color>
        <Color x:Key="NebulaSurface3">#222228</Color>

        <!-- Borders -->
        <Color x:Key="NebulaBorder">#2A2A30</Color>
        <Color x:Key="NebulaBorderSubtle">#1F1F24</Color>

        <!-- Text -->
        <Color x:Key="NebulaText">#E2E2E8</Color>
        <Color x:Key="NebulaTextMuted">#8888A0</Color>
        <Color x:Key="NebulaTextSubtle">#44445A</Color>

        <!-- Accent — Nebula Purple -->
        <Color x:Key="NebulaAccent">#8B6FD4</Color>
        <Color x:Key="NebulaAccentHover">#9D82E2</Color>
        <Color x:Key="NebulaAccentPressed">#7A5EC3</Color>

        <!-- Semantic -->
        <Color x:Key="NebulaSuccess">#4CAF7D</Color>
        <Color x:Key="NebulaWarning">#E8A838</Color>
        <Color x:Key="NebulaError">#E05C5C</Color>

        <!-- Git status colors -->
        <Color x:Key="NebulaGitModified">#E8A838</Color>
        <Color x:Key="NebulaGitNew">#4CAF7D</Color>
        <Color x:Key="NebulaGitDeleted">#E05C5C</Color>
        <Color x:Key="NebulaGitConflict">#E05C5C</Color>

        <!-- Brushes — base -->
        <SolidColorBrush x:Key="NebulaBgBrush"           Color="{StaticResource NebulaBg}"/>
        <SolidColorBrush x:Key="NebulaSurfaceBrush"      Color="{StaticResource NebulaSurface}"/>
        <SolidColorBrush x:Key="NebulaSurface2Brush"     Color="{StaticResource NebulaSurface2}"/>
        <SolidColorBrush x:Key="NebulaSurface3Brush"     Color="{StaticResource NebulaSurface3}"/>
        <SolidColorBrush x:Key="NebulaBorderBrush"       Color="{StaticResource NebulaBorder}"/>
        <SolidColorBrush x:Key="NebulaBorderSubtleBrush" Color="{StaticResource NebulaBorderSubtle}"/>
        <SolidColorBrush x:Key="NebulaTextBrush"         Color="{StaticResource NebulaText}"/>
        <SolidColorBrush x:Key="NebulaTextMutedBrush"    Color="{StaticResource NebulaTextMuted}"/>
        <SolidColorBrush x:Key="NebulaTextSubtleBrush"   Color="{StaticResource NebulaTextSubtle}"/>
        <SolidColorBrush x:Key="NebulaAccentBrush"       Color="{StaticResource NebulaAccent}"/>
        <SolidColorBrush x:Key="NebulaAccentHoverBrush"  Color="{StaticResource NebulaAccentHover}"/>
        <SolidColorBrush x:Key="NebulaAccentPressedBrush" Color="{StaticResource NebulaAccentPressed}"/>
        <SolidColorBrush x:Key="NebulaSuccessBrush"      Color="{StaticResource NebulaSuccess}"/>
        <SolidColorBrush x:Key="NebulaWarningBrush"      Color="{StaticResource NebulaWarning}"/>
        <SolidColorBrush x:Key="NebulaErrorBrush"        Color="{StaticResource NebulaError}"/>

        <!-- Brushes — derived (computed by ThemeManager at runtime) -->
        <SolidColorBrush x:Key="NebulaAccentSurfaceBrush"  Color="#188B6FD4"/>
        <SolidColorBrush x:Key="NebulaAccentSurface2Brush" Color="#258B6FD4"/>
        <SolidColorBrush x:Key="NebulaErrorSurfaceBrush"   Color="#16E05C5C"/>
        <SolidColorBrush x:Key="NebulaErrorBorderBrush"    Color="#40E05C5C"/>
        <SolidColorBrush x:Key="NebulaErrorTextBrush"      Color="#E8A0A0"/>
        <SolidColorBrush x:Key="NebulaHoverOverlayBrush"   Color="#0DFFFFFF"/>
        <SolidColorBrush x:Key="NebulaPressOverlayBrush"   Color="#07FFFFFF"/>

        <!-- Brushes — glass / depth (semi-transparent, show layers beneath) -->
        <SolidColorBrush x:Key="NebulaGlassSurfaceBrush"  Color="#D916161A"/>
        <SolidColorBrush x:Key="NebulaGlassBgBrush"       Color="#CC0F0F11"/>
        <SolidColorBrush x:Key="NebulaGlassCardBrush"     Color="#CC1C1C21"/>

        <!-- Toolbar background — swapped by AppearanceViewModel (solid or glass) -->
        <SolidColorBrush x:Key="NebulaToolbarBrush"       Color="{StaticResource NebulaSurface}"/>

        <!-- Visual-effects flags — false by default, overridden by AppearanceViewModel -->
        <x:Boolean x:Key="NebulaGlowBlobsEnabled">False</x:Boolean>
        <x:Boolean x:Key="NebulaSidebarBlurEnabled">False</x:Boolean>
        <x:Boolean x:Key="NebulaGlassEnabled">False</x:Boolean>

    </Styles.Resources>

    <!-- ── Window ─────────────────────────────────────── -->
    <Style Selector="Window">
        <Setter Property="Background"  Value="{DynamicResource NebulaBgBrush}"/>
        <Setter Property="FontFamily"  Value="Inter,Segoe UI,system-ui,sans-serif"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Foreground"  Value="{DynamicResource NebulaTextBrush}"/>
    </Style>

    <!-- ── TextBlock ──────────────────────────────────── -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource NebulaTextBrush}"/>
    </Style>

    <!-- ── TextBox ────────────────────────────────────── -->
    <Style Selector="TextBox">
        <Setter Property="Background"       Value="{DynamicResource NebulaSurfaceBrush}"/>
        <Setter Property="Foreground"       Value="{DynamicResource NebulaTextBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="4"/>
        <Setter Property="Padding"          Value="8,6"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="CaretBrush"       Value="{DynamicResource NebulaAccentBrush}"/>
        <Setter Property="SelectionBrush"   Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>

    <!-- ── Button — base ─────────────────────────────── -->
    <Style Selector="Button">
        <Setter Property="Background"       Value="{DynamicResource NebulaSurface2Brush}"/>
        <Setter Property="Foreground"       Value="{DynamicResource NebulaTextBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="4"/>
        <Setter Property="Padding"          Value="12,6"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="Cursor"           Value="Hand"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaSurface3Brush}"/>
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaSurfaceBrush}"/>
    </Style>

    <!-- ── Button.accent — filled purple ─────────────── -->
    <Style Selector="Button.accent">
        <Setter Property="Background"      Value="{DynamicResource NebulaAccentBrush}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentHoverBrush}"/>
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentPressedBrush}"/>
    </Style>

    <!-- ── Button.template-card — selectable option card ─ -->
    <Style Selector="Button.template-card">
        <Setter Property="Background"      Value="{DynamicResource NebulaSurfaceBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource NebulaTextBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="5"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style Selector="Button.template-card:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaSurface2Brush}"/>
    </Style>
    <!-- Selected state: accent border + tinted background -->
    <Style Selector="Button.template-card.selected">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>
    <Style Selector="Button.template-card.selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
    </Style>
    <Style Selector="Button.template-card.selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurface2Brush}"/>
    </Style>
    <!-- Disabled (coming soon) -->
    <Style Selector="Button.template-card:disabled">
        <Setter Property="Opacity" Value="0.4"/>
        <Setter Property="Cursor"  Value="Arrow"/>
    </Style>

    <!-- ── Button.ghost — transparent background ─────── -->
    <Style Selector="Button.ghost">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaHoverOverlayBrush}"/>
    </Style>
    <Style Selector="Button.ghost:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaPressOverlayBrush}"/>
    </Style>

    <!-- ── Nav items — inactive default ─────────────────── -->
    <Style Selector="TextBlock.nav-icon">
        <Setter Property="Foreground" Value="{DynamicResource NebulaTextMutedBrush}"/>
    </Style>
    <Style Selector="TextBlock.nav-label">
        <Setter Property="Foreground" Value="{DynamicResource NebulaTextMutedBrush}"/>
    </Style>

    <!-- ── Nav items — active (accent highlight + left bar) ─── -->
    <Style Selector="Button.ghost.active">
        <Setter Property="Background"      Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaAccentBrush}"/>
        <Setter Property="BorderThickness" Value="3,0,0,0"/>
        <Setter Property="CornerRadius"    Value="0,4,4,0"/>
    </Style>
    <Style Selector="Button.ghost.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurface2Brush}"/>
    </Style>
    <Style Selector="Button.ghost.active TextBlock.nav-icon">
        <Setter Property="Foreground" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>
    <Style Selector="Button.ghost.active TextBlock.nav-label">
        <Setter Property="Foreground" Value="{DynamicResource NebulaTextBrush}"/>
    </Style>

    <!-- ── Button.project-card — grid-view project card ────── -->
    <Style Selector="Button.project-card">
        <Setter Property="Background"      Value="{DynamicResource NebulaSurface2Brush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource NebulaTextBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.project-card:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaSurface3Brush}"/>
    </Style>
    <Style Selector="Button.project-card:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaSurfaceBrush}"/>
    </Style>

    <!-- ── Button.template-image — full-bleed image card ───
         Provides 2-px border (accent when selected), no internal
         background fill — content is responsible for its own visuals. -->
    <Style Selector="Button.template-image">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <!-- Suppress Fluent hover/press overlay — the card visuals handle that -->
    <Style Selector="Button.template-image:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.template-image:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <!-- Selected: accent border -->
    <Style Selector="Button.template-image.selected">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>
    <!-- Disabled (coming soon): dimmed -->
    <Style Selector="Button.template-image:disabled">
        <Setter Property="Opacity" Value="0.45"/>
        <Setter Property="Cursor"  Value="Arrow"/>
    </Style>

    <!-- ── Button.view-toggle — grid/list mode buttons ─────
         Accent-tint active state, NO left-bar indicator so
         they don't render as a bracket `{` shape.           -->
    <Style Selector="Button.view-toggle">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Padding"         Value="7,5"/>
    </Style>
    <Style Selector="Button.view-toggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaHoverOverlayBrush}"/>
    </Style>
    <Style Selector="Button.view-toggle:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaPressOverlayBrush}"/>
    </Style>
    <!-- Active: accent-tint fill, no border/bar -->
    <Style Selector="Button.view-toggle.active">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
    </Style>
    <Style Selector="Button.view-toggle.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurface2Brush}"/>
    </Style>
    <!-- Icon tint when active -->
    <Style Selector="Button.view-toggle.active Border.nav-icon-box">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>

    <!-- Nav icon box (small colored square) -->
    <Style Selector="Border.nav-icon-box">
        <Setter Property="Background" Value="{DynamicResource NebulaTextSubtleBrush}"/>
    </Style>
    <Style Selector="Button.ghost.active Border.nav-icon-box">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>

    <!-- Nav icon ring (circle outline) -->
    <Style Selector="Border.nav-icon-ring">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaTextSubtleBrush}"/>
    </Style>
    <Style Selector="Button.ghost.active Border.nav-icon-ring">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>

    <!-- Search container box -->
    <Style Selector="Border.search-box">
        <Setter Property="Background"      Value="{DynamicResource NebulaSurface2Brush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Height"          Value="34"/>
    </Style>
    <Style Selector="Border.search-box:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaTextSubtleBrush}"/>
    </Style>

    <!-- Borderless TextBox (used inside search-box container) -->
    <Style Selector="TextBox.borderless">
        <Setter Property="Background"              Value="Transparent"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="Padding"                 Value="0,0,8,0"/>
        <Setter Property="CornerRadius"            Value="0"/>
        <Setter Property="VerticalAlignment"       Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <!-- Suppress inner Fluent-template border in every state so no double-border flash -->
    <Style Selector="TextBox.borderless /template/ Border">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="TextBox.borderless:pointerover /template/ Border">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="TextBox.borderless:focus /template/ Border">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="TextBox.borderless:focus">
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- ── Button.ide-row — settings IDE list rows ──────── -->
    <Style Selector="Button.ide-row">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius"    Value="0"/>
        <Setter Property="Foreground"      Value="{DynamicResource NebulaTextBrush}"/>
    </Style>
    <Style Selector="Button.ide-row:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaHoverOverlayBrush}"/>
    </Style>
    <!-- Selected row: accent tint -->
    <Style Selector="Button.ide-row.selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
    </Style>
    <Style Selector="Button.ide-row.selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurface2Brush}"/>
    </Style>
    <!-- Radio indicator — unselected -->
    <Style Selector="Button.ide-row Border.radio-outer">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="Background"  Value="Transparent"/>
    </Style>
    <Style Selector="Button.ide-row Ellipse.radio-inner">
        <Setter Property="Fill"       Value="Transparent"/>
        <Setter Property="IsVisible"  Value="False"/>
    </Style>
    <!-- Radio indicator — selected -->
    <Style Selector="Button.ide-row.selected Border.radio-outer">
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>
    <Style Selector="Button.ide-row.selected Ellipse.radio-inner">
        <Setter Property="Fill"      Value="{DynamicResource NebulaAccentBrush}"/>
        <Setter Property="IsVisible" Value="True"/>
    </Style>

    <!-- ── Button.theme-chip — preset selector pill ────── -->
    <Style Selector="Button.theme-chip">
        <Setter Property="Background"      Value="{DynamicResource NebulaSurface2Brush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Foreground"      Value="{DynamicResource NebulaTextMutedBrush}"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.theme-chip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaHoverOverlayBrush}"/>
    </Style>
    <!-- Selected: accent border + slightly brighter text -->
    <Style Selector="Button.theme-chip.selected">
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaAccentBrush}"/>
        <Setter Property="Background"      Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource NebulaTextBrush}"/>
    </Style>
    <Style Selector="Button.theme-chip.selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurface2Brush}"/>
    </Style>

    <!-- ── Button.settings-tab ───────────────────────────── -->
    <Style Selector="Button.settings-tab">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Padding"         Value="12,6"/>
        <Setter Property="Foreground"      Value="{DynamicResource NebulaTextMutedBrush}"/>
    </Style>
    <Style Selector="Button.settings-tab:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaHoverOverlayBrush}"/>
    </Style>
    <Style Selector="Button.settings-tab.active">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NebulaTextBrush}"/>
    </Style>
    <Style Selector="Button.settings-tab.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource NebulaAccentSurface2Brush}"/>
    </Style>

    <!-- ── Engine Versions page ──────────────────────── -->

    <!-- engine-row: hoverable container for each installed engine -->
    <Style Selector="Border.engine-row">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.engine-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource NebulaHoverOverlayBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaBorderBrush}"/>
    </Style>

    <!-- engine-badge: version pill on the left of each row -->
    <Style Selector="Border.engine-badge">
        <Setter Property="Background"      Value="{DynamicResource NebulaSurface3Brush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="5"/>
        <Setter Property="Width"           Value="46"/>
        <Setter Property="Height"          Value="28"/>
        <Setter Property="Padding"         Value="6,2"/>
    </Style>
    <Style Selector="Border.engine-badge TextBlock">
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="FontWeight"   Value="Medium"/>
        <Setter Property="Foreground"   Value="{DynamicResource NebulaTextMutedBrush}"/>
        <Setter Property="LetterSpacing" Value="0.4"/>
    </Style>
    <!-- active (default engine) badge — accent tint -->
    <Style Selector="Border.engine-badge.active">
        <Setter Property="Background"  Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>
    <Style Selector="Border.engine-badge.active TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource NebulaAccentBrush}"/>
    </Style>

    <!-- ── ContextMenu ───────────────────────────────── -->
    <Style Selector="ContextMenu">
        <Setter Property="Background"       Value="{DynamicResource NebulaSurface2Brush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="5"/>
        <Setter Property="Padding"          Value="4"/>
    </Style>

    <!-- ── MenuItem ──────────────────────────────────── -->
    <Style Selector="MenuItem">
        <Setter Property="Foreground"  Value="{DynamicResource NebulaTextBrush}"/>
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="Padding"     Value="10,6"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Cursor"      Value="Hand"/>
    </Style>
    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background"    Value="{DynamicResource NebulaAccentSurfaceBrush}"/>
        <Setter Property="CornerRadius"  Value="3"/>
    </Style>
    <Style Selector="MenuItem:pointerover > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource NebulaTextBrush}"/>
    </Style>

    <!-- ── Separator ─────────────────────────────────── -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource NebulaBorderBrush}"/>
        <Setter Property="Height"     Value="1"/>
        <Setter Property="Margin"     Value="6,3"/>
    </Style>

    <!-- ── ScrollViewer ───────────────────────────────── -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ── ScrollBar ──────────────────────────────────── -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</Styles>
