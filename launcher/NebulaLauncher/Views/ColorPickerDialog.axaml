<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NebulaLauncher.Views.ColorPickerDialog"
        Title="Pick a Color"
        Width="340"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Inter,Segoe UI,system-ui,sans-serif"
        FontSize="13">

    <Grid RowDefinitions="Auto,Auto,Auto"
          Margin="20,16,20,20">

        <!-- Color picker control -->
        <ColorPicker Grid.Row="0"
                     x:Name="Picker"
                     HorizontalAlignment="Stretch"
                     Margin="0,0,0,16"/>

        <!-- Divider -->
        <Border Grid.Row="1"
                Height="1"
                Background="{DynamicResource NebulaBorderBrush}"
                Margin="0,0,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel" MinWidth="72" Click="OnCancel"/>
            <Button Classes="accent" Content="Apply" MinWidth="72" Click="OnApply"/>
        </StackPanel>

    </Grid>

</Window>
