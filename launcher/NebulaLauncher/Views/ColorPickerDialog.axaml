<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NebulaLauncher.Views.ColorPickerDialog"
        Title="Pick a Color"
        Width="360"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Inter,Segoe UI,system-ui,sans-serif"
        FontSize="13">

    <StackPanel Margin="16,14,16,16" Spacing="12">

        <!-- Full inline color view -->
        <ColorView x:Name="Picker"
                   HorizontalAlignment="Stretch"/>

        <!-- Divider -->
        <Border Height="1"
                Background="{DynamicResource NebulaBorderBrush}"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel" MinWidth="72" Click="OnCancel"/>
            <Button Classes="accent" Content="Apply" MinWidth="72" Click="OnApply"/>
        </StackPanel>

    </StackPanel>

</Window>
