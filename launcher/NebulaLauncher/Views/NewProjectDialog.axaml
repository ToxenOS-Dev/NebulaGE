<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NebulaLauncher.ViewModels"
        x:Class="NebulaLauncher.Views.NewProjectDialog"
        x:DataType="vm:NewProjectDialogViewModel"
        Title="New Project"
        Width="760" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource NebulaBgBrush}"
        Foreground="{DynamicResource NebulaTextBrush}"
        FontFamily="Inter,Segoe UI,system-ui,sans-serif"
        FontSize="13">

    <!--
        Layout:
          Row 0 — header bar (title + subtitle left | "PROJECT SETTINGS" right)
          Row 1 — body: template grid left | vertical sep | form sidebar right
          Row 2 — footer: Cancel + Create Project
    -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ──────────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource NebulaBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,1,240">

                <!-- Title + subtitle -->
                <Border Grid.Column="0" Padding="24,16,24,14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="New Project"
                                   FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="Configure your new NebulaGE project"
                                   FontSize="11"
                                   Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Vertical divider -->
                <Border Grid.Column="1" Background="{DynamicResource NebulaBorderBrush}"/>

                <!-- Sidebar header label -->
                <Border Grid.Column="2" Padding="20,0">
                    <TextBlock Text="PROJECT SETTINGS"
                               FontSize="10" FontWeight="Medium"
                               LetterSpacing="1.2"
                               Foreground="{DynamicResource NebulaTextSubtleBrush}"
                               VerticalAlignment="Center"/>
                </Border>

            </Grid>
        </Border>

        <!-- ── Body ────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="*,1,240">

            <!-- ── Left: mode toggle + template grid / clone form ── -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*"
                  Margin="20,18,16,16">

                <!-- Mode toggle pills -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Margin="0,0,0,14">
                    <Button Classes="settings-tab"
                            Classes.active="{Binding IsNewMode}"
                            Command="{Binding SetNewModeCommand}"
                            Padding="12,5">New Project</Button>
                    <Button Classes="settings-tab"
                            Classes.active="{Binding IsCloneMode}"
                            Command="{Binding SetCloneModeCommand}"
                            Padding="12,5">Clone from GitHub</Button>
                </StackPanel>

                <!-- ── New Project: template cards ────────────── -->
                <ItemsControl Grid.Row="1"
                              IsVisible="{Binding IsNewMode}"
                              ItemsSource="{Binding TemplateCards}"
                              Margin="0,0,-8,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:TemplateCardViewModel">

                            <Button Classes="template-image"
                                    Classes.selected="{Binding IsSelected}"
                                    IsEnabled="{Binding IsAvailable}"
                                    Command="{Binding SelectCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Margin="0,0,8,8">

                                <!-- Clipped visual content — clips gradient + blob to button radius -->
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Panel>

                                        <!-- 1: Solid base colour -->
                                        <Border Background="{Binding CardBgBrush}"/>

                                        <!-- 2: Decorative glow blob (top-left, bleeds outside) -->
                                        <Canvas IsHitTestVisible="False" ClipToBounds="True">
                                            <Ellipse Canvas.Left="-50" Canvas.Top="-70"
                                                     Width="300" Height="300"
                                                     Fill="{Binding BlobBrush}"
                                                     Opacity="0.24">
                                                <Ellipse.Effect><BlurEffect Radius="60"/></Ellipse.Effect>
                                            </Ellipse>
                                        </Canvas>

                                        <!-- 3: Bottom gradient fade (transparent → near-black) -->
                                        <Border VerticalAlignment="Bottom" Height="90">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent"  Offset="0"/>
                                                    <GradientStop Color="#D2060609"    Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <!-- 4: Text overlay — bottom-right -->
                                        <StackPanel HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,13,11"
                                                    Spacing="2">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10"
                                                       Foreground="#99FFFFFF"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>

                                        <!-- 5: SOON badge — top-right corner -->
                                        <Border IsVisible="{Binding IsComingSoon}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,8,8,0"
                                                Padding="6,3"
                                                CornerRadius="4"
                                                Background="{DynamicResource NebulaSurface3Brush}"
                                                BorderBrush="{DynamicResource NebulaBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="SOON"
                                                       FontSize="8" FontWeight="Medium"
                                                       LetterSpacing="0.8"
                                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                                        </Border>

                                    </Panel>
                                </Border>
                            </Button>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Clone from GitHub form ─────────────────── -->
                <StackPanel Grid.Row="1"
                            IsVisible="{Binding IsCloneMode}"
                            Spacing="16">

                    <!-- URL input -->
                    <StackPanel Spacing="7">
                        <TextBlock Text="REPOSITORY URL"
                                   FontSize="10" FontWeight="Medium"
                                   LetterSpacing="1.2"
                                   Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                        <TextBox Text="{Binding CloneUrl}"
                                 Watermark="https://github.com/user/repo"
                                 FontFamily="Cascadia Code,JetBrains Mono,monospace"
                                 FontSize="12"/>
                        <!-- Error hint -->
                        <TextBlock IsVisible="{Binding CloneUrlError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Text="{Binding CloneUrlError}"
                                   FontSize="11"
                                   Foreground="{DynamicResource NebulaErrorBrush}"/>
                    </StackPanel>

                    <!-- Repo preview card (shown when URL is valid) -->
                    <Border IsVisible="{Binding HasValidCloneUrl}"
                            Background="{DynamicResource NebulaSurface2Brush}"
                            BorderBrush="{DynamicResource NebulaAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="WILL CLONE"
                                       FontSize="9" FontWeight="Medium"
                                       LetterSpacing="1.0"
                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                            <TextBlock Text="{Binding CloneRepoSlug}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NebulaAccentBrush}"/>
                            <TextBlock Text="{Binding CloneUrl}"
                                       FontSize="10"
                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- Empty state prompt -->
                    <StackPanel IsVisible="{Binding !HasValidCloneUrl}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8"
                                Margin="0,20">
                        <TextBlock Text="Paste a GitHub repo URL above"
                                   FontSize="13"
                                   Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="The project will be cloned into your selected location."
                                   FontSize="11"
                                   Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="320"/>
                    </StackPanel>

                </StackPanel>

            </Grid>

            <!-- Column separator -->
            <Border Grid.Column="1" Background="{DynamicResource NebulaBorderBrush}"/>

            <!-- ── Right sidebar: project settings ───────── -->
            <StackPanel Grid.Column="2"
                        Margin="20,20,20,16"
                        Spacing="22">

                <!-- Project name -->
                <StackPanel Spacing="7">
                    <TextBlock Text="PROJECT NAME"
                               FontSize="10" FontWeight="Medium"
                               LetterSpacing="1.2"
                               Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                    <TextBox x:Name="NameInput"
                             Text="{Binding ProjectName}"
                             Watermark="MyGame"/>
                </StackPanel>

                <!-- Location — plain text + link button, no container box -->
                <StackPanel Spacing="6">
                    <TextBlock Text="LOCATION"
                               FontSize="10" FontWeight="Medium"
                               LetterSpacing="1.2"
                               Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                    <TextBlock Text="{Binding Location}"
                               FontSize="12"
                               Foreground="{DynamicResource NebulaTextMutedBrush}"
                               TextWrapping="Wrap"/>
                    <Button Classes="ghost"
                            HorizontalAlignment="Left"
                            Padding="0,2"
                            Click="OnBrowseLocation">
                        <TextBlock Text="Change folder →"
                                   FontSize="11"
                                   Foreground="{DynamicResource NebulaAccentBrush}"/>
                    </Button>
                </StackPanel>

            </StackPanel>

        </Grid>

        <!-- ── Footer ──────────────────────────────────────── -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource NebulaBorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel>

                <!-- Error banner — only visible when ErrorMessage is set -->
                <Border IsVisible="{Binding HasError}"
                        Background="{DynamicResource NebulaErrorSurfaceBrush}"
                        BorderBrush="{DynamicResource NebulaErrorBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="20,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource NebulaErrorTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Classes="ghost"
                                Padding="8,4"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Command="{Binding DismissErrorCommand}"
                                ToolTip.Tip="Dismiss">
                            <TextBlock Text="✕" FontSize="11"
                                       Foreground="{DynamicResource NebulaErrorTextBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Buttons row -->
                <Grid ColumnDefinitions="*,Auto,8,Auto"
                      Margin="24,13,24,16">
                    <Button Grid.Column="1"
                            Content="Cancel"
                            MinWidth="88" Padding="14,7"
                            Click="OnCancel"/>
                    <Button Grid.Column="3"
                            Classes="accent"
                            Content="{Binding CreateButtonLabel}"
                            MinWidth="140" Padding="14,7"
                            IsEnabled="{Binding CanCreate}"
                            Click="OnCreate"/>
                </Grid>

            </StackPanel>
        </Border>

    </Grid>

</Window>
