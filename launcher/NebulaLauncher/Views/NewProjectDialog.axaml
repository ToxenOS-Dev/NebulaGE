<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NebulaLauncher.ViewModels"
        x:Class="NebulaLauncher.Views.NewProjectDialog"
        x:DataType="vm:NewProjectDialogViewModel"
        Title="New Project"
        Width="480"
        SizeToContent="Height"
        MinHeight="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Inter,Segoe UI,system-ui,sans-serif"
        FontSize="13">

    <!--
        Grid rows:
          0 — Title       (Auto)
          1 — Form        (Auto — content drives height, SizeToContent handles window)
          2 — Separator   (Auto)
          3 — Buttons     (Auto — always pinned at bottom)
    -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
          Margin="24,20,24,24">

        <!-- ── Title ─────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="New Project"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <!-- ── Form ──────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Spacing="16">

            <!-- Project Name -->
            <StackPanel Spacing="6">
                <TextBlock Text="Project Name"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                <TextBox Text="{Binding ProjectName}"
                         Watermark="MyGame"
                         x:Name="NameInput"/>
            </StackPanel>

            <!-- Location -->
            <StackPanel Spacing="6">
                <TextBlock Text="Location"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                <Grid ColumnDefinitions="*,8,Auto">
                    <TextBox Grid.Column="0" Text="{Binding Location}"/>
                    <Button Grid.Column="2" Content="Browse" MinWidth="72"
                            Click="OnBrowseLocation"/>
                </Grid>
            </StackPanel>

            <!-- Template cards -->
            <StackPanel Spacing="6">
                <TextBlock Text="Template"
                           FontSize="11" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                <ItemsControl ItemsSource="{Binding TemplateCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:TemplateCardViewModel">
                            <Button Classes="template-card"
                                    Classes.selected="{Binding IsSelected}"
                                    IsEnabled="{Binding IsAvailable}"
                                    Command="{Binding SelectCommand}"
                                    MinWidth="120"
                                    Padding="12,10">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="12" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="10"
                                               Foreground="{DynamicResource NebulaTextMutedBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Path preview -->
            <Border Background="{DynamicResource NebulaSurfaceBrush}"
                    BorderBrush="{DynamicResource NebulaBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,9">
                <StackPanel Spacing="3">
                    <TextBlock Text="Will be created at"
                               FontSize="10"
                               Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                    <TextBlock Text="{Binding FullPath}"
                               FontSize="12"
                               Foreground="{DynamicResource NebulaTextMutedBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- ── Divider ────────────────────────────────────── -->
        <Border Grid.Row="2"
                Height="1"
                Background="{DynamicResource NebulaBorderBrush}"
                Margin="0,20,0,0"/>

        <!-- ── Buttons — always at bottom ────────────────── -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button Content="Cancel" MinWidth="80" Click="OnCancel"/>
            <Button Classes="accent"
                    Content="+ Create Project"
                    MinWidth="128"
                    IsEnabled="{Binding CanCreate}"
                    Click="OnCreate"/>
        </StackPanel>

    </Grid>

</Window>
