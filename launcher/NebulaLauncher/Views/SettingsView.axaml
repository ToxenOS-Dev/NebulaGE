<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NebulaLauncher.ViewModels"
             xmlns:views="using:NebulaLauncher.Views"
             x:Class="NebulaLauncher.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Tab bar ─────────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource NebulaBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12,20,0">
            <StackPanel Orientation="Horizontal" Spacing="4">

                <Button Classes="settings-tab"
                        Classes.active="{Binding IsGeneralActive}"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static vm:SettingsSection.General}">
                    General
                </Button>

                <Button Classes="settings-tab"
                        Classes.active="{Binding IsThemesActive}"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static vm:SettingsSection.Themes}">
                    Themes
                </Button>

            </StackPanel>
        </Border>

        <!-- ── General tab ────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      IsVisible="{Binding IsGeneralActive}">
            <StackPanel Margin="28,24" Spacing="0" MaxWidth="640">

                <!-- ══════════════════════════════════════════════
                     SECTION: Development Environment
                     ══════════════════════════════════════════════ -->
                <TextBlock Text="DEVELOPMENT ENVIRONMENT"
                           FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                           LetterSpacing="1.2"
                           Margin="0,0,0,14"/>

                <!-- Preferred IDE -->
                <StackPanel Spacing="6" Margin="0,0,0,24">
                    <TextBlock Text="Preferred IDE"
                               FontSize="13" FontWeight="Medium"/>
                    <TextBlock Text="Used when opening a project from the launcher or via Open in IDE."
                               FontSize="12" Foreground="{DynamicResource NebulaTextMutedBrush}"
                               Margin="0,0,0,10"/>

                    <!-- IDE list -->
                    <Border IsVisible="{Binding !NoIdesFound}"
                            Background="{DynamicResource NebulaSurfaceBrush}"
                            BorderBrush="{DynamicResource NebulaBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding DetectedIdes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:IdeOptionViewModel">
                                    <Button Classes="ide-row"
                                            Classes.selected="{Binding IsSelected}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding SelectCommand}"
                                            Padding="14,11">
                                        <Grid ColumnDefinitions="Auto,*,Auto">

                                            <!-- Radio indicator -->
                                            <Border Grid.Column="0"
                                                    Width="16" Height="16"
                                                    CornerRadius="8"
                                                    BorderThickness="1.5"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,12,0"
                                                    Classes="radio-outer">
                                                <Ellipse Width="8" Height="8"
                                                         Classes="radio-inner"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Name -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"/>

                                            <!-- Path -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ExePath}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0,0,0"/>

                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- No IDEs found -->
                    <Border IsVisible="{Binding NoIdesFound}"
                            Background="{DynamicResource NebulaSurfaceBrush}"
                            BorderBrush="{DynamicResource NebulaBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="No IDEs detected"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                       TextWrapping="Wrap">
                                Install VS Code, VSCodium, Rider, CLion, Neovim, or Emacs
                                and restart NebulaGE to detect it automatically.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource NebulaBorderBrush}"
                        Margin="0,0,0,24"/>

                <!-- ══════════════════════════════════════════════
                     SECTION: Projects
                     ══════════════════════════════════════════════ -->
                <TextBlock Text="PROJECTS"
                           FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                           LetterSpacing="1.2"
                           Margin="0,0,0,14"/>

                <!-- Default project location -->
                <StackPanel Spacing="6" Margin="0,0,0,8">
                    <TextBlock Text="Default Project Location"
                               FontSize="13" FontWeight="Medium"/>
                    <TextBlock Text="Where new projects are created by default."
                               FontSize="12"
                               Foreground="{DynamicResource NebulaTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding DefaultProjectLocation}"/>
                        <Button Grid.Column="2"
                                Content="Browse"
                                MinWidth="72"
                                Click="OnBrowseLocation"/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Themes tab ──────────────────────────────────── -->
        <views:ThemesView Grid.Row="1"
                          IsVisible="{Binding IsThemesActive}"
                          DataContext="{Binding Themes}"/>

    </Grid>

</UserControl>
