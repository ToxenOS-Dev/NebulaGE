<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NebulaLauncher.ViewModels"
             xmlns:views="using:NebulaLauncher.Views"
             x:Class="NebulaLauncher.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Tab bar — glass surface ────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource NebulaGlassSurfaceBrush}"
                BorderBrush="{DynamicResource NebulaBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12,20,0">
            <StackPanel Orientation="Horizontal" Spacing="4">

                <Button Classes="settings-tab"
                        Classes.active="{Binding IsGeneralActive}"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static vm:SettingsSection.General}">
                    General
                </Button>

                <Button Classes="settings-tab"
                        Classes.active="{Binding IsThemesActive}"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="{x:Static vm:SettingsSection.Themes}">
                    Themes
                </Button>

            </StackPanel>
        </Border>

        <!-- ── General tab ────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      IsVisible="{Binding IsGeneralActive}">
            <StackPanel Margin="28,24" Spacing="0" MaxWidth="640">

                <!-- ══════════════════════════════════════════════
                     SECTION: Development Environment
                     ══════════════════════════════════════════════ -->
                <TextBlock Text="DEVELOPMENT ENVIRONMENT"
                           FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                           LetterSpacing="1.2"
                           Margin="0,0,0,14"/>

                <!-- Preferred IDE -->
                <StackPanel Spacing="6" Margin="0,0,0,24">
                    <TextBlock Text="Preferred IDE"
                               FontSize="13" FontWeight="Medium"/>
                    <TextBlock Text="Used when opening a project from the launcher or via Open in IDE."
                               FontSize="12" Foreground="{DynamicResource NebulaTextMutedBrush}"
                               Margin="0,0,0,10"/>

                    <!-- IDE list -->
                    <Border IsVisible="{Binding !NoIdesFound}"
                            Background="{DynamicResource NebulaSurfaceBrush}"
                            BorderBrush="{DynamicResource NebulaBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding DetectedIdes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:IdeOptionViewModel">
                                    <Button Classes="ide-row"
                                            Classes.selected="{Binding IsSelected}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding SelectCommand}"
                                            Padding="14,11">
                                        <Grid ColumnDefinitions="Auto,*,Auto">

                                            <!-- Radio indicator -->
                                            <Border Grid.Column="0"
                                                    Width="16" Height="16"
                                                    CornerRadius="8"
                                                    BorderThickness="1.5"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,12,0"
                                                    Classes="radio-outer">
                                                <Ellipse Width="8" Height="8"
                                                         Classes="radio-inner"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Name -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"/>

                                            <!-- Path -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ExePath}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0,0,0"/>

                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- No IDEs found -->
                    <Border IsVisible="{Binding NoIdesFound}"
                            Background="{DynamicResource NebulaSurfaceBrush}"
                            BorderBrush="{DynamicResource NebulaBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="No IDEs detected"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                       TextWrapping="Wrap">
                                Install VS Code, VSCodium, Rider, CLion, Neovim, or Emacs
                                and restart NebulaGE to detect it automatically.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource NebulaBorderBrush}"
                        Margin="0,0,0,24"/>

                <!-- ══════════════════════════════════════════════
                     SECTION: GitHub Account
                     ══════════════════════════════════════════════ -->
                <TextBlock Text="GITHUB ACCOUNT"
                           FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                           LetterSpacing="1.2"
                           Margin="0,0,0,14"/>

                <StackPanel Spacing="0" Margin="0,0,0,24">

                    <!-- ── Connected ─────────────────────────────── -->
                    <Border IsVisible="{Binding GitHub.HasUser}"
                            Background="{DynamicResource NebulaSurfaceBrush}"
                            BorderBrush="{DynamicResource NebulaBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14">
                        <Grid ColumnDefinitions="Auto,*,Auto" >

                            <!-- GitHub octocat mark -->
                            <Path Grid.Column="0"
                                  Width="22" Height="22"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="0,0,14,0"
                                  Fill="{DynamicResource NebulaTextBrush}"
                                  Data="M 8,0 C 3.58,0 0,3.58 0,8 C 0,11.54 2.29,14.53 5.47,15.59
                                        C 5.87,15.66 6.02,15.42 6.02,15.21 C 6.02,15.02 6.01,14.39 6.01,13.72
                                        C 4,14.09 3.48,13.23 3.32,12.78 C 3.23,12.55 2.84,11.84 2.5,11.65
                                        C 2.22,11.5 1.82,11.13 2.49,11.12 C 3.12,11.11 3.57,11.7 3.72,11.94
                                        C 4.44,13.15 5.59,12.81 6.05,12.6 C 6.12,12.08 6.33,11.73 6.56,11.53
                                        C 4.78,11.33 2.92,10.64 2.92,7.58 C 2.92,6.71 3.23,5.99 3.74,5.43
                                        C 3.66,5.23 3.38,4.41 3.82,3.31 C 3.82,3.31 4.49,3.1 6.02,4.13
                                        C 6.66,3.95 7.34,3.86 8.02,3.86 C 8.7,3.86 9.38,3.95 10.02,4.13
                                        C 11.55,3.09 12.22,3.31 12.22,3.31 C 12.66,4.41 12.38,5.23 12.3,5.43
                                        C 12.81,5.99 13.12,6.7 13.12,7.58 C 13.12,10.65 11.25,11.33 9.47,11.53
                                        C 9.76,11.78 10.01,12.26 10.01,13.01 C 10.01,14.08 10,14.94 10,15.21
                                        C 10,15.42 10.15,15.67 10.55,15.59 C 13.71,14.53 16,11.53 16,8
                                        C 16,3.58 12.42,0 8,0 Z"/>

                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Connected as"
                                           FontSize="11"
                                           Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                                <TextBlock Text="{Binding GitHub.User}"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding !GitHub.IsBusy}"
                                    Command="{Binding GitHub.LogoutCommand}">
                                Logout
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── Not connected ──────────────────────────── -->
                    <Border IsVisible="{Binding GitHub.NoUser}"
                            Background="{DynamicResource NebulaSurfaceBrush}"
                            BorderBrush="{DynamicResource NebulaBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="Not connected"
                                           FontSize="13" FontWeight="Medium"/>
                                <!-- Awaiting browser auth hint -->
                                <TextBlock IsVisible="{Binding GitHub.AwaitingBrowserAuth}"
                                           Text="Complete sign-in in your browser, then click Refresh."
                                           FontSize="11"
                                           Foreground="{DynamicResource NebulaAccentBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock IsVisible="{Binding !GitHub.AwaitingBrowserAuth}"
                                           Text="Connect to clone repositories and see repo links in projects."
                                           FontSize="11"
                                           Foreground="{DynamicResource NebulaTextMutedBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Classes="accent"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    IsEnabled="{Binding !GitHub.IsBusy}"
                                    Command="{Binding GitHub.LoginCommand}"
                                    Content="{Binding GitHub.LoginButtonLabel}"/>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- Divider -->
                <Border Height="1"
                        Background="{DynamicResource NebulaBorderBrush}"
                        Margin="0,0,0,24"/>

                <!-- ══════════════════════════════════════════════
                     SECTION: Projects
                     ══════════════════════════════════════════════ -->
                <TextBlock Text="PROJECTS"
                           FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                           LetterSpacing="1.2"
                           Margin="0,0,0,14"/>

                <!-- Default project location -->
                <StackPanel Spacing="6" Margin="0,0,0,8">
                    <TextBlock Text="Default Project Location"
                               FontSize="13" FontWeight="Medium"/>
                    <TextBlock Text="Where new projects are created by default."
                               FontSize="12"
                               Foreground="{DynamicResource NebulaTextMutedBrush}"
                               Margin="0,0,0,6"/>
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding DefaultProjectLocation}"/>
                        <Button Grid.Column="2"
                                Content="Browse"
                                MinWidth="72"
                                Click="OnBrowseLocation"/>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Themes tab ──────────────────────────────────── -->
        <!--
            Use ContentControl so IsVisible binds to SettingsViewModel (this DataContext),
            not to ThemesViewModel. Setting DataContext on the ThemesView directly would
            lose the SettingsViewModel scope before IsVisible resolves.
        -->
        <ContentControl Grid.Row="1"
                        IsVisible="{Binding IsThemesActive}"
                        Content="{Binding Themes}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="vm:ThemesViewModel">
                    <views:ThemesView/>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

    </Grid>

</UserControl>
