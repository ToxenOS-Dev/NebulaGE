<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NebulaLauncher.Views.SplashScreen"
        Width="620" Height="360"
        CanResize="False"
        SystemDecorations="None"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur,Blur,Transparent"
        Background="Transparent">

    <Panel>

        <!-- ── Drop shadow + rounded dark card ───────────── -->
        <Border CornerRadius="14"
                Background="{DynamicResource NebulaBgBrush}"
                BoxShadow="0 24 72 0 #AA000000"/>

        <!-- ── Ambient glow blob (top-right) ─────────────── -->
        <Canvas IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Canvas.Left="380" Canvas.Top="-100"
                     Width="320" Height="320"
                     Fill="{DynamicResource NebulaAccentBrush}"
                     Opacity="0.08">
                <Ellipse.Effect><BlurEffect Radius="90"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Canvas.Left="-60" Canvas.Top="200"
                     Width="200" Height="200"
                     Fill="{DynamicResource NebulaAccentBrush}"
                     Opacity="0.06">
                <Ellipse.Effect><BlurEffect Radius="60"/></Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!-- ── Thin top accent line ───────────────────────── -->
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Height="2"
                Margin="0,0,0,0"
                CornerRadius="14,14,0,0"
                Background="{DynamicResource NebulaAccentBrush}"
                Opacity="0.6"/>

        <!-- ── Main content ───────────────────────────────── -->
        <Grid RowDefinitions="*,Auto" Margin="48,36,48,32">

            <!-- Center: logo + project info -->
            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">

                <!-- Logo with soft glow ring -->
                <Panel Width="80" Height="80"
                       HorizontalAlignment="Center">
                    <Ellipse Width="100" Height="100"
                             Fill="{DynamicResource NebulaAccentBrush}"
                             Opacity="0.14">
                        <Ellipse.Effect><BlurEffect Radius="22"/></Ellipse.Effect>
                    </Ellipse>
                    <Image Source="/Assets/NebulaGE-Logo-NoBackground.jpg"
                           Width="80" Height="80"
                           RenderOptions.BitmapInterpolationMode="HighQuality"/>
                </Panel>

                <!-- Project name -->
                <TextBlock x:Name="ProjectNameText"
                           FontSize="26" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource NebulaTextBrush}"/>

                <!-- Engine version badge -->
                <Border HorizontalAlignment="Center"
                        Background="{DynamicResource NebulaSurface2Brush}"
                        BorderBrush="{DynamicResource NebulaBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="10,4">
                    <TextBlock x:Name="VersionText"
                               FontSize="11"
                               Foreground="{DynamicResource NebulaTextSubtleBrush}"
                               HorizontalAlignment="Center"/>
                </Border>

            </StackPanel>

            <!-- Bottom: thin progress bar + status text -->
            <StackPanel Grid.Row="1" Spacing="10">

                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             CornerRadius="2"
                             Foreground="{DynamicResource NebulaAccentBrush}"
                             Background="{DynamicResource NebulaSurface3Brush}"/>

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               x:Name="StatusText"
                               Text="Opening project…"
                               FontSize="11"
                               Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="Nebula GE"
                               FontSize="11"
                               Foreground="{DynamicResource NebulaTextSubtleBrush}"
                               Opacity="0.5"/>
                </Grid>

            </StackPanel>

        </Grid>

    </Panel>

</Window>
