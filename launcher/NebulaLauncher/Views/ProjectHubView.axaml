<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NebulaLauncher.ViewModels"
             x:Class="NebulaLauncher.Views.ProjectHubView"
             x:DataType="vm:ProjectHubViewModel"
             Background="#0F0F11">

    <DockPanel>

        <!-- ── Toolbar ──────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Padding="20,14"
                BorderBrush="#2A2A30"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Search -->
                <TextBox Grid.Column="0"
                         Watermark="Search projects..."
                         Text="{Binding SearchText}"
                         MaxWidth="320"
                         HorizontalAlignment="Left"/>

                <!-- Actions -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="accent"
                            Command="{Binding NewProjectCommand}">
                        + New Project
                    </Button>
                    <Button Command="{Binding OpenFromDiskCommand}">
                        Open Folder
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Section label ────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Padding="20,12,20,6">
            <TextBlock Text="RECENT PROJECTS"
                       FontSize="10"
                       FontWeight="Medium"
                       Foreground="#44445A"
                       LetterSpacing="1.2"/>
        </Border>

        <!-- ── Project list / empty state ───────────────────── -->
        <Panel DockPanel.Dock="Top">

            <!-- List -->
            <ScrollViewer IsVisible="{Binding HasProjects}">
                <ItemsControl ItemsSource="{Binding Projects}"
                              Margin="12,0,12,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ProjectItemViewModel">
                            <Button Classes="ghost"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="8,9"
                                    CornerRadius="4"
                                    Command="{Binding OpenCommand}">
                                <Grid ColumnDefinitions="*,Auto">

                                    <!-- Left: name + path -->
                                    <StackPanel Grid.Column="0"
                                                Spacing="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   Foreground="#E2E2E8"/>
                                        <TextBlock Text="{Binding Path}"
                                                   FontSize="11"
                                                   Foreground="#44445A"/>
                                    </StackPanel>

                                    <!-- Right: badges + date -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">

                                        <!-- Git branch badge -->
                                        <Border IsVisible="{Binding HasGitRepo}"
                                                Background="#8B6FD418"
                                                CornerRadius="3"
                                                Padding="6,2">
                                            <TextBlock Text="{Binding GitBranch}"
                                                       FontSize="11"
                                                       Foreground="#8B6FD4"/>
                                        </Border>

                                        <!-- Engine version badge -->
                                        <Border Background="#1C1C21"
                                                CornerRadius="3"
                                                Padding="6,2">
                                            <TextBlock Text="{Binding EngineVersion}"
                                                       FontSize="11"
                                                       Foreground="#8888A0"/>
                                        </Border>

                                        <!-- Last opened -->
                                        <TextBlock Text="{Binding LastOpenedDisplay}"
                                                   FontSize="11"
                                                   Foreground="#44445A"
                                                   VerticalAlignment="Center"
                                                   MinWidth="70"/>

                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel IsVisible="{Binding IsEmpty}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="0,80">
                <TextBlock Text="No projects yet"
                           FontSize="15"
                           FontWeight="Medium"
                           Foreground="#44445A"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Create a new project or open an existing folder to get started."
                           FontSize="13"
                           Foreground="#44445A"
                           HorizontalAlignment="Center"/>
                <Button Classes="accent"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0"
                        Command="{Binding NewProjectCommand}">
                    + New Project
                </Button>
            </StackPanel>

        </Panel>

    </DockPanel>

</UserControl>
