<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NebulaLauncher.ViewModels"
             x:Class="NebulaLauncher.Views.ProjectHubView"
             x:DataType="vm:ProjectHubViewModel">

    <DockPanel>

        <!-- ── Toolbar — frosted glass surface ──────────────── -->
        <Border DockPanel.Dock="Top"
                Padding="20,14"
                Background="{DynamicResource NebulaGlassSurfaceBrush}"
                BorderBrush="{DynamicResource NebulaBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">

                <TextBox Grid.Column="0"
                         Watermark="Search projects..."
                         Text="{Binding SearchText}"
                         MaxWidth="320"
                         HorizontalAlignment="Left"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="accent" Click="OnNewProject">
                        + New Project
                    </Button>
                    <Button Click="OnOpenFromDisk">
                        Open Folder
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Error banner ─────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasError}"
                Background="{DynamicResource NebulaErrorSurfaceBrush}"
                BorderBrush="{DynamicResource NebulaErrorBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="40">

                <TextBlock Grid.Column="0"
                           Text="⚠"
                           Foreground="{DynamicResource NebulaErrorBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource NebulaErrorTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>

                <Button Grid.Column="2"
                        Classes="ghost"
                        Foreground="{DynamicResource NebulaErrorBrush}"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Command="{Binding DismissErrorCommand}">
                    ✕
                </Button>

            </Grid>
        </Border>

        <!-- ── Section label ────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Padding="20,12,20,6">
            <TextBlock Text="RECENT PROJECTS"
                       FontSize="10"
                       FontWeight="Medium"
                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                       LetterSpacing="1.2"/>
        </Border>

        <!-- ── Project list / empty state ───────────────────── -->
        <Panel DockPanel.Dock="Top">

            <!-- List -->
            <ScrollViewer IsVisible="{Binding HasProjects}">
                <ItemsControl ItemsSource="{Binding Projects}"
                              Margin="12,0,12,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ProjectItemViewModel">
                            <!--
                                Glass card: semi-transparent surface so the ambient
                                glow blobs show softly through the gap between cards.
                                A subtle top-edge highlight adds the frosted glass sheen.
                            -->
                            <Border Background="{DynamicResource NebulaGlassCardBrush}"
                                    BorderBrush="{DynamicResource NebulaBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,0,0">

                                <!-- Top-edge glass highlight line -->
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="{DynamicResource NebulaBorder}"  Offset="0"/>
                                        <GradientStop Color="{DynamicResource NebulaBorderSubtle}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>

                                <Button Classes="ghost"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="12,10"
                                        CornerRadius="5"
                                        Command="{Binding OpenCommand}">

                                    <!-- ── Context menu ──────────── -->
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Open"
                                                      Command="{Binding OpenCommand}"/>
                                            <MenuItem Header="Open in IDE"
                                                      Command="{Binding OpenInIdeCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="Show in Files"
                                                      Command="{Binding ShowInFilesCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="Remove from List"
                                                      Command="{Binding RemoveCommand}"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>

                                    <Grid ColumnDefinitions="*,Auto">

                                        <!-- Left: name + path -->
                                        <StackPanel Grid.Column="0"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Path}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                                        </StackPanel>

                                        <!-- Right: badges + date -->
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">

                                            <Border IsVisible="{Binding HasGitRepo}"
                                                    Background="{DynamicResource NebulaAccentSurfaceBrush}"
                                                    CornerRadius="3"
                                                    Padding="6,2">
                                                <TextBlock Text="{Binding GitBranch}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource NebulaAccentBrush}"/>
                                            </Border>

                                            <Border Background="{DynamicResource NebulaSurface2Brush}"
                                                    CornerRadius="3"
                                                    Padding="6,2">
                                                <TextBlock Text="{Binding EngineVersion}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                                            </Border>

                                            <TextBlock Text="{Binding LastOpenedDisplay}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                                       VerticalAlignment="Center"
                                                       MinWidth="70"/>

                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel IsVisible="{Binding IsEmpty}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="0,80">
                <TextBlock Text="No projects yet"
                           FontSize="15"
                           FontWeight="Medium"
                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Create a new project or open an existing folder to get started."
                           FontSize="13"
                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                           HorizontalAlignment="Center"/>
                <Button Classes="accent"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0"
                        Click="OnNewProject">
                    + New Project
                </Button>
            </StackPanel>

        </Panel>

    </DockPanel>

</UserControl>
