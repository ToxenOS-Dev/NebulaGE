<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NebulaLauncher.ViewModels"
        xmlns:views="using:NebulaLauncher.Views"
        x:Class="NebulaLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Nebula GE"
        Icon="/Assets/NebulaGE-Logo.jpg"
        Width="1060" Height="700"
        MinWidth="820" MinHeight="560"
        TransparencyLevelHint="AcrylicBlur,Blur,Transparent"
        Background="Transparent">

    <!--
        Layer stack (bottom → top):
          0  Solid background floor       — always present; fallback when glass is off
          0b Glass acrylic floor          — IsVisible={DynamicResource NebulaGlassEnabled}
                                            composites with desktop compositor (Digger),
                                            so frosted-glass effect is clearly visible
          1  Ambient blob canvas          — IsVisible={DynamicResource NebulaGlowBlobsEnabled}
          2  Main UI grid
               Sidebar: solid Border (always, bottom), then ExperimentalAcrylicBorder
                        (IsVisible=NebulaSidebarBlurEnabled, on top of solid so it
                        isn't buried — corrected z-order)
               Content: transparent so glass/blobs bleed through card gaps
    -->
    <Panel>

        <!-- ── 0: Always-solid floor ─────────────────────────── -->
        <Border Background="{DynamicResource NebulaBgBrush}"/>

        <!-- ── 0b: Glass acrylic floor (off by default) ─────── -->
        <ExperimentalAcrylicBorder IsVisible="{DynamicResource NebulaGlassEnabled}">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                              TintColor="{DynamicResource NebulaBg}"
                                              TintOpacity="0.62"
                                              MaterialOpacity="0.90"/>
            </ExperimentalAcrylicBorder.Material>
            <Panel/>
        </ExperimentalAcrylicBorder>

        <!-- ── 1: Global ambient blobs (off by default) ──────── -->
        <Grid IsHitTestVisible="False"
              IsVisible="{DynamicResource NebulaGlowBlobsEnabled}">
            <Canvas>
                <Ellipse Canvas.Left="-160" Canvas.Top="320"
                         Width="680" Height="680"
                         Fill="{DynamicResource NebulaAccentBrush}"
                         Opacity="0.10">
                    <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Canvas.Left="800" Canvas.Top="-160"
                         Width="460" Height="460"
                         Fill="{DynamicResource NebulaAccentBrush}"
                         Opacity="0.06">
                    <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Canvas.Left="860" Canvas.Top="380"
                         Width="220" Height="220"
                         Fill="{DynamicResource NebulaAccentBrush}"
                         Opacity="0.05">
                    <Ellipse.Effect><BlurEffect Radius="50"/></Ellipse.Effect>
                </Ellipse>
            </Canvas>
        </Grid>

        <!-- ── 2+3: Main UI ──────────────────────────────────── -->
        <Grid ColumnDefinitions="200,*">

            <!-- ── Sidebar ──────────────────────────────────── -->
            <Panel Grid.Column="0">

                <!-- Solid base — always present; provides background when blur is off
                     and acts as the opaque fallback on systems without compositor blur -->
                <Border Background="{DynamicResource NebulaSurfaceBrush}"/>

                <!-- Acrylic overlay — sits ABOVE the solid base so it isn't buried.
                     BackgroundSource="Digger" blurs the desktop behind the window
                     (compositor-level), not the solid border below it in the tree. -->
                <ExperimentalAcrylicBorder IsVisible="{DynamicResource NebulaSidebarBlurEnabled}">
                    <ExperimentalAcrylicBorder.Material>
                        <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                                      TintColor="{DynamicResource NebulaSurface}"
                                                      TintOpacity="0.72"
                                                      MaterialOpacity="0.90"/>
                    </ExperimentalAcrylicBorder.Material>
                    <Panel/>
                </ExperimentalAcrylicBorder>

                <!-- Sidebar own ambient blobs — off by default -->
                <Grid IsHitTestVisible="False"
                      IsVisible="{DynamicResource NebulaGlowBlobsEnabled}">
                    <Canvas>
                        <Ellipse Canvas.Left="-60" Canvas.Top="-80"
                                 Width="280" Height="280"
                                 Fill="{DynamicResource NebulaAccentBrush}"
                                 Opacity="0.18">
                            <Ellipse.Effect><BlurEffect Radius="65"/></Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Canvas.Left="-40" Canvas.Top="520"
                                 Width="200" Height="200"
                                 Fill="{DynamicResource NebulaAccentBrush}"
                                 Opacity="0.10">
                            <Ellipse.Effect><BlurEffect Radius="50"/></Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                </Grid>

                <!-- Nav content + right separator -->
                <Border BorderBrush="{DynamicResource NebulaBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel>

                        <!-- Brand -->
                        <Border DockPanel.Dock="Top"
                                Padding="18,14,16,14"
                                BorderBrush="{DynamicResource NebulaBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Spacing="2">

                                <!-- Logo + name on one row -->
                                <StackPanel Orientation="Horizontal" Spacing="10"
                                            VerticalAlignment="Center">
                                    <Image Source="/Assets/NebulaGE-Logo-NoBackground.jpg"
                                           Width="32" Height="32"
                                           RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="Nebula GE"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="v0.1.0"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource NebulaTextSubtleBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ── GitHub indicator ──────────────── -->
                                <Border Margin="0,8,0,0"
                                        Background="{DynamicResource NebulaSurface2Brush}"
                                        BorderBrush="{DynamicResource NebulaBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="8,5">
                                    <StackPanel Orientation="Horizontal" Spacing="6">

                                        <!-- GitHub octocat-like SVG mark -->
                                        <Path Width="13" Height="13"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"
                                              Fill="{DynamicResource NebulaTextSubtleBrush}"
                                              Data="M 8,0 C 3.58,0 0,3.58 0,8
                                                    C 0,11.54 2.29,14.53 5.47,15.59
                                                    C 5.87,15.66 6.02,15.42 6.02,15.21
                                                    C 6.02,15.02 6.01,14.39 6.01,13.72
                                                    C 4,14.09 3.48,13.23 3.32,12.78
                                                    C 3.23,12.55 2.84,11.84 2.5,11.65
                                                    C 2.22,11.5 1.82,11.13 2.49,11.12
                                                    C 3.12,11.11 3.57,11.7 3.72,11.94
                                                    C 4.44,13.15 5.59,12.81 6.05,12.6
                                                    C 6.12,12.08 6.33,11.73 6.56,11.53
                                                    C 4.78,11.33 2.92,10.64 2.92,7.58
                                                    C 2.92,6.71 3.23,5.99 3.74,5.43
                                                    C 3.66,5.23 3.38,4.41 3.82,3.31
                                                    C 3.82,3.31 4.49,3.1 6.02,4.13
                                                    C 6.66,3.95 7.34,3.86 8.02,3.86
                                                    C 8.7,3.86 9.38,3.95 10.02,4.13
                                                    C 11.55,3.09 12.22,3.31 12.22,3.31
                                                    C 12.66,4.41 12.38,5.23 12.3,5.43
                                                    C 12.81,5.99 13.12,6.7 13.12,7.58
                                                    C 13.12,10.65 11.25,11.33 9.47,11.53
                                                    C 9.76,11.78 10.01,12.26 10.01,13.01
                                                    C 10.01,14.08 10,14.94 10,15.21
                                                    C 10,15.42 10.15,15.67 10.55,15.59
                                                    C 13.71,14.53 16,11.53 16,8
                                                    C 16,3.58 12.42,0 8,0 Z"/>

                                        <!-- Connected: username -->
                                        <TextBlock IsVisible="{Binding GitHub.HasUser}"
                                                   Text="{Binding GitHub.User}"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource NebulaTextBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Auth: device code chip -->
                                        <Border IsVisible="{Binding GitHub.ShowDeviceCode}"
                                                Background="{DynamicResource NebulaSurface3Brush}"
                                                BorderBrush="{DynamicResource NebulaAccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding GitHub.DeviceCode}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource NebulaAccentBrush}"/>
                                        </Border>

                                        <!-- Auth: waiting for code -->
                                        <TextBlock IsVisible="{Binding GitHub.AwaitingWithoutCode}"
                                                   Text="Connecting…"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource NebulaAccentBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Idle: not connected -->
                                        <TextBlock IsVisible="{Binding GitHub.IsNotConnectedIdle}"
                                                   Text="Not connected"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>

                        <!-- Settings pinned to bottom -->
                        <Border DockPanel.Dock="Bottom"
                                Padding="0,6,0,6"
                                BorderBrush="{DynamicResource NebulaBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Button Classes="ghost"
                                    Classes.active="{Binding IsSettingsSelected}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,9"
                                    CornerRadius="0"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="{x:Static vm:NavItem.Settings}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Gear icon as Unicode -->
                                    <TextBlock Text="⚙"
                                               Classes="nav-icon"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Settings"
                                               Classes="nav-label"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <!-- Nav items -->
                        <StackPanel DockPanel.Dock="Top"
                                    Spacing="1"
                                    Margin="0,12,0,0">

                            <!-- Projects — 2×2 grid icon -->
                            <Button Classes="ghost"
                                    Classes.active="{Binding IsProjectsSelected}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,9"
                                    CornerRadius="0"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="{x:Static vm:NavItem.Projects}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- 2×2 grid icon -->
                                    <Grid Width="13" Height="13"
                                          ColumnDefinitions="5,3,5"
                                          RowDefinitions="5,3,5"
                                          VerticalAlignment="Center">
                                        <Border Grid.Row="0" Grid.Column="0"
                                                CornerRadius="1.5"
                                                Classes="nav-icon-box"/>
                                        <Border Grid.Row="0" Grid.Column="2"
                                                CornerRadius="1.5"
                                                Classes="nav-icon-box"/>
                                        <Border Grid.Row="2" Grid.Column="0"
                                                CornerRadius="1.5"
                                                Classes="nav-icon-box"/>
                                        <Border Grid.Row="2" Grid.Column="2"
                                                CornerRadius="1.5"
                                                Classes="nav-icon-box"/>
                                    </Grid>
                                    <TextBlock Text="Projects"
                                               Classes="nav-label"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Engine Versions — ring icon -->
                            <Button Classes="ghost"
                                    Classes.active="{Binding IsEnginesSelected}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,9"
                                    CornerRadius="0"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="{x:Static vm:NavItem.Engines}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Ring icon -->
                                    <Border Width="13" Height="13"
                                            CornerRadius="7"
                                            BorderThickness="2"
                                            Background="Transparent"
                                            Classes="nav-icon-ring"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="Engine Versions"
                                               Classes="nav-label"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>

                    </DockPanel>
                </Border>

            </Panel>

            <!-- ── Content area ──────────────────────────────── -->
            <Panel Grid.Column="1">

            <ContentControl Content="{Binding CurrentPage}">
                <ContentControl.DataTemplates>

                    <DataTemplate DataType="vm:ProjectHubViewModel">
                        <views:ProjectHubView/>
                    </DataTemplate>

                    <DataTemplate DataType="vm:EngineVersionsViewModel">
                        <views:EngineVersionsView/>
                    </DataTemplate>

                    <DataTemplate DataType="vm:SettingsViewModel">
                        <views:SettingsView/>
                    </DataTemplate>

                    <DataTemplate DataType="vm:StubPageViewModel">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Message}"
                                           Foreground="{DynamicResource NebulaTextMutedBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>

                </ContentControl.DataTemplates>
            </ContentControl>

            <!-- ── Download tray ─────────────────────────── -->
            <!--
                Floats at the bottom of the content column (not the sidebar).
                Visible only when there are active or recently-completed downloads.
            -->
            <Border VerticalAlignment="Bottom"
                    IsVisible="{Binding Downloads.HasDownloads}"
                    Background="{DynamicResource NebulaSurface2Brush}"
                    BorderBrush="{DynamicResource NebulaBorderBrush}"
                    BorderThickness="0,1,0,0"
                    BoxShadow="0 -4 20 0 #44000000"
                    Padding="0,0,0,0">
                <StackPanel>

                    <!-- Header row -->
                    <Border Padding="16,8,16,8"
                            BorderBrush="{DynamicResource NebulaBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Down-arrow icon -->
                            <Path Width="11" Height="11"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource NebulaAccentBrush}"
                                  Data="M 5,0 L 5,8 M 1,4 L 5,8 L 9,4"/>
                            <TextBlock Text="Downloads"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Download rows -->
                    <ItemsControl ItemsSource="{Binding Downloads.Downloads}"
                                  Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:DownloadItemViewModel">
                                <Border Padding="16,10"
                                        BorderBrush="{DynamicResource NebulaBorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="Auto,*,Auto">

                                        <!-- Status icon: ↓ while active, ✓ done, ✕ failed -->
                                        <Panel Grid.Column="0"
                                               Width="18"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0">
                                            <TextBlock Text="↓" FontSize="13"
                                                       IsVisible="{Binding IsActive}"
                                                       Foreground="{DynamicResource NebulaAccentBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="✓" FontSize="13"
                                                       IsVisible="{Binding IsComplete}"
                                                       Foreground="{DynamicResource NebulaSuccessBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="✕" FontSize="13"
                                                       IsVisible="{Binding IsFailed}"
                                                       Foreground="{DynamicResource NebulaErrorBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Panel>

                                        <!-- Name + progress -->
                                        <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">

                                            <!-- Name + slug -->
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Slug}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource NebulaTextSubtleBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Progress bar + status -->
                                            <Grid ColumnDefinitions="*,8,Auto">
                                                <ProgressBar Grid.Column="0"
                                                             Value="{Binding Progress}"
                                                             Minimum="0" Maximum="1"
                                                             Height="4"
                                                             CornerRadius="2"
                                                             Foreground="{DynamicResource NebulaAccentBrush}"
                                                             Background="{DynamicResource NebulaSurface3Brush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource NebulaTextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                        </StackPanel>

                                        <!-- Cancel / Dismiss button -->
                                        <Button Grid.Column="2"
                                                Classes="ghost"
                                                Margin="14,0,0,0"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Command="{Binding CancelCommand}"
                                                IsVisible="{Binding IsActive}"
                                                ToolTip.Tip="Cancel">
                                            <TextBlock Text="✕" FontSize="11"
                                                       Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                                        </Button>
                                        <Button Grid.Column="2"
                                                Classes="ghost"
                                                Margin="14,0,0,0"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Command="{Binding DismissCommand}"
                                                IsVisible="{Binding IsFinished}"
                                                ToolTip.Tip="Dismiss">
                                            <TextBlock Text="✕" FontSize="11"
                                                       Foreground="{DynamicResource NebulaTextMutedBrush}"/>
                                        </Button>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

            </Panel>

        </Grid>

    </Panel>

</Window>
